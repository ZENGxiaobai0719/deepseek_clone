# =========================
# Auth (Clerk)
# =========================
# Required: Clerk publishable key (frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Required: Clerk secret key (server)
CLERK_SECRET_KEY=sk_test_xxx
# Optional: sign-in route in this project
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# =========================
# LLM Provider (DeepSeek)
# =========================
# Required: your DeepSeek API key.
# IMPORTANT: must be a valid key with available balance.
DEEPSEEK_API_KEY=sk-xxx

# Optional: custom DeepSeek-compatible gateway.
# Leave empty to use official endpoint: https://api.deepseek.com
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com

# =========================
# Database
# =========================
# Required: Postgres connection string
DATABASE_URL=postgresql://username:password@host:5432/dbname
